      "parameters": {
        "jsCode": "const allItems = $input.all();\n\nlet imagePath = '';\nlet audioPath = $('Generate Audio').first().json.path;\n\nfor (const item of allItems) {\n  const p = item.json?.path || '';\n  if (p.includes('.jpg') || p.includes('.jpeg') || p.includes('.png')) {\n    imagePath = p;\n  }\n  if (p.includes('.wav') || p.includes('.mp3')) {\n    audioPath = p;\n  }\n}\n\n// If still empty check nested\nif (!imagePath || !audioPath) {\n  for (const item of allItems) {\n    for (const key of Object.keys(item.json || {})) {\n      const val = String(item.json[key] || '');\n      if (!imagePath && (val.includes('.jpg') || val.includes('.png'))) imagePath = val;\n      if (!audioPath && (val.includes('.wav') || val.includes('.mp3'))) audioPath = val;\n    }\n  }\n}\n\nreturn [{ json: { image: imagePath, audio: audioPath } }];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -1120,
        -144
